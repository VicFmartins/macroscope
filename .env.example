# =============================================================================
# MacroScope - Environment Variables
# Copy this file to .env for local Docker usage.
# Do not commit your real secrets.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=macroscope
DB_USER=macroscope
DB_PASSWORD=macroscope_secret
DATABASE_URL=
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- Redis --------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# --- External APIs ------------------------------------------------------------
EXCHANGE_RATES_API_KEY=your_exchange_rates_key_here
GEMINI_API_KEY=your_gemini_key_here
INSIGHTS_MODEL=gemini-2.5-flash
INSIGHTS_CACHE_TTL_SECONDS=43200
INSIGHTS_TIMEOUT_SECONDS=20

# --- Backend ------------------------------------------------------------------
PORT=8080
SERVER_PORT=8080
COLLECTION_INTERVAL_MS=21600000
ALLOWED_ORIGINS=http://localhost:3000
HEALTH_SHOW_DETAILS=when_authorized

# --- Frontend -----------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
