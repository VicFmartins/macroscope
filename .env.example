# =============================================================================
# MacroScope - Environment Variables
# Copy this file to .env for local Docker usage.
# Do not commit your real secrets.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=macroscope
DB_USER=macroscope
DB_PASSWORD=macroscope_secret
DATABASE_URL=
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- Redis --------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# --- External APIs ------------------------------------------------------------
EXCHANGE_RATES_API_KEY=your_exchange_rates_key_here
GEMINI_API_KEY=your_gemini_key_here
INSIGHTS_MODEL=gemini-2.5-flash
INSIGHTS_CACHE_TTL_SECONDS=43200
INSIGHTS_TIMEOUT_SECONDS=20
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Backend ------------------------------------------------------------------
APP_ENV=local
PORT=8080
SERVER_PORT=8080
COLLECTION_INTERVAL_MS=21600000
COLLECTION_TRIGGER_API_KEY=replace_with_a_secure_random_value
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_MAX_TRIGGER_REQUESTS=5
ALLOWED_ORIGINS=http://localhost:3000
HEALTH_SHOW_DETAILS=when_authorized

# --- Frontend -----------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_COLLECTION_TRIGGER_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
